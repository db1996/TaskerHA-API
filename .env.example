PORT=3000
HOST=0.0.0.0

# Path to the SQLite file (default: ./data/app.db)
DB_PATH=

# Set to 'true' in production — rejects requests not coming through Cloudflare
REQUIRE_CF=false

# Shared secret your Android app sends in every request as the X-App-Token header.
# Keep this short and embed it in the app. Not truly secret for open-source apps,
# but it filters automated scanners that hit random endpoints.
APP_TOKEN=change-me

# Secret for the GET /stats endpoint (only you need this)
ADMIN_KEY=change-me-too
